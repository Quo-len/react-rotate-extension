{
  "manifest_version": 3,
  "name": "Page Flip",
  "version": "4.2",
  "description": "Effortlessly rotate any web page left, right, or reset to portrait. Supports keyboard shortcuts and provides a live preview for better readability.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "commands": {
    "rotate-left": {
      "suggested_key": {
        "default": "Ctrl+Insert"
      },
      "description": "Rotate the page counter-clockwise"
    },
    "rotate-right": {
      "suggested_key": {
        "default": "Ctrl+Delete"
      },
      "description": "Rotate the page clockwise"
    },
    "rotate-reset": {
      "suggested_key": {
        "default": "Ctrl+Home"
      },
      "description": "Reset page rotation"
    }
  }
}
